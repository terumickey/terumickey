# ===== りそなマイページ ログイン情報 =====
RESONA_LOGIN_URL=https://mypage.resona-saiyo.com/2028/
RESONA_ID=your_mypage_id
RESONA_PASSWORD=your_mypage_password

# 空席通知の対象にしたい日程(カンマ区切り、部分一致)。
# 「RESONA Business Academy Premium」の日程選択ページに表示される日付表記に合わせています。
TARGET_DATES=2026/08/05

# ===== メール通知設定(Gmail) =====
# Googleアカウントで2段階認証を有効にした上で発行した
# 「アプリパスワード」(16桁)を使ってください。通常のログインパスワードは使えません。
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 通知を受け取るメールアドレス
NOTIFY_TO=cgek0315@mail3.doshisha.ac.jp
